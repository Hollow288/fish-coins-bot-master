# ==============================
# NoneBot2 基础配置
# ==============================

# 监听地址
HOST=0.0.0.0
# 监听端口
PORT=8080
# 命令起始符
COMMAND_START=["","/"]
# 命令分隔符
COMMAND_SEP=["."]


# ==============================
# 数据库配置 (MySQL)
# ==============================

# 数据库用户名
DATABASE_USERNAME=root
# 数据库密码
DATABASE_PASSWORD=your_password
# 数据库主机地址
DATABASE_HOST=127.0.0.1
# 数据库端口 (默认 3306)
DATABASE_PORT=3306
# 数据库名称
DATABASE_NAME=hottadata


# ==============================
# MinIO 对象存储配置
# ==============================

# MinIO 服务端点 (供 minio-py 客户端使用, 不带协议前缀)
ENDPOINT=127.0.0.1:9000
# MinIO Access Key
ACCESS_KEY=your_access_key
# MinIO Secret Key
SECRET_KEY=your_secret_key

# MinIO 素材资源 URL 前缀 (带协议, 以 / 结尾)
MINIO_HOST=http://127.0.0.1:9000/your-bucket/material/basic/
# MinIO 字体资源 URL 前缀
FONT_HOST=http://127.0.0.1:9000/your-bucket/fonts/
# MinIO 背景图资源 URL 前缀
BACKGROUND_HOST=http://127.0.0.1:9000/your-bucket/background/


# ==============================
# AI 聊天 / 图像识别配置
# ==============================

# AI 图像生成接口地址 (ai_chat 插件用, 注意: 不是识图)
AI_IMAGE_URI=
# AI 图像生成 API Key
AI_IMAGE_APIKEY=

# AI 图像识别接口地址 (sticker_collector 等用, /api/v1/ai/image/recognize)
AI_IMAGE_RECOGNIZE_URI=
# AI 图像识别 API Key
AI_IMAGE_RECOGNIZE_APIKEY=

# AI 去除文字接口地址
AI_REMOVE_TEXT_URI=
# AI 文本对话接口地址
AI_TEXT_URI=
# AI 文本对话 API Key
AI_TEXT_APIKEY=

# Agent 别名查询接口地址 (/api/v1/agent/ask)
AGENT_ASK_URI=
# Agent 别名查询 API Key
AGENT_ASK_APIKEY=


# ==============================
# 管理员配置
# ==============================

# 管理员 QQ 号 (用于权限控制)
ADMIN_ID=


# ==============================
# 人格模仿插件配置 (persona_mirror)
# ==============================

# 人格模仿管理员 QQ 号, 多个用逗号分隔 (留空则回退到 ADMIN_ID)
PERSONA_ADMIN_IDS=

# 摘要生成 - 每批处理的消息数量 (默认 30, 最小 5)
PERSONA_SUMMARY_BATCH_SIZE=30
# 摘要生成 - 采样消息数量 (默认 25, 最小 5)
PERSONA_SUMMARY_SAMPLE_SIZE=25
# 模仿发言 - 采样消息数量 (默认 8, 最小 3)
PERSONA_SPEAK_SAMPLE_SIZE=8
# 最近上下文消息数量 (默认 12, 最小 3)
PERSONA_RECENT_CONTEXT_SIZE=12
# 摘要生成定时任务间隔, 单位分钟 (默认 30, 最小 5)
PERSONA_SUMMARY_INTERVAL_MINUTES=30
# 是否启用定时摘要任务 (默认 true)
PERSONA_SCHEDULER_ENABLED=true
# 自动回复冷却时间, 单位秒 (默认 180, 最小 0)
PERSONA_AUTO_REPLY_COOLDOWN_SECONDS=180
# 自动回复最小关键词长度 (默认 2, 最小 1)
PERSONA_AUTO_REPLY_MIN_KEYWORD_LENGTH=2


# ==============================
# B 站动态推送插件配置 (bilibili/dynamics_push.py)
# ==============================

# bot 账号 B 站登录 Cookie, 用于 feed/all 接口拉关注 UP 主的动态时间线
# (旧接口 feed/space 和 space.bilibili.com 已被 B 站对机房 IP 风控, 必须用登录态走 feed/all 绕过)
# 抓取方式: 浏览器登录 https://www.bilibili.com 后 F12 -> Application -> Cookies -> https://www.bilibili.com
# 注意: bot 账号必须先关注 dynamics_list.json 里所有要监控的 UP 主, 否则 feed/all 拿不到他们的动态
BILI_SESSDATA=
BILI_JCT=
BILI_BUVID3=


# ==============================
# 表情包采集 / 识别插件配置 (sticker_collector)
# ==============================

# 是否启用全局表情包采集 (默认 true)
STICKER_COLLECTOR_ENABLED=true
# 表情包文件大小上限, 单位字节, 超过则跳过不入库 (默认 512000, 即 500KB)
STICKER_COLLECTOR_MAX_SIZE_BYTES=1024000
# 是否启用 AI 识别定时任务 (默认 true)
STICKER_RECOGNIZE_ENABLED=true
# 识别定时任务间隔, 单位分钟 (默认 10, 最小 1)
STICKER_RECOGNIZE_INTERVAL_MINUTES=10
# 每次定时任务最多识别的表情包数量 (默认 20, 最小 1)
STICKER_RECOGNIZE_BATCH_SIZE=20
# 单张表情包最大重试次数 (默认 3, 最小 1)
STICKER_RECOGNIZE_MAX_ATTEMPTS=3
# 张与张之间的节流毫秒数, 防止触发上游 429 (默认 500, 最小 0)
STICKER_RECOGNIZE_THROTTLE_MS=500

